  </joint>
  <joint name="gripper_r_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.570796 0 0" />
    <parent link="wrist_r" />
    <child link="gripper_r" />
  </joint>
  <joint name="head_joint" type="fixed">
    <origin xyz="0 0 0.3648" rpy="0 0 0" />
    <parent link="torso" />
    <child link="head" />
  </joint>
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 -0.077217" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="imu" />
  </joint>
  <joint name="main_camera_joint" type="fixed">
    <origin xyz="0.144 0 0.192" rpy="0 1.570796 0" />
    <parent link="torso" />
    <child link="main_camera" />
  </joint>
  <joint name="shoulder_l_joint" type="revolute">
    <origin xyz="0 0.1728 0" rpy="1.570796 0 0" />
    <parent link="torso" />
    <child link="shoulder_l" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1" lower="-1.570796" upper="1.570796" />
    <dynamics damping="0.3" friction="0.05" />
  </joint>
  <joint name="shoulder_r_joint" type="revolute">
    <origin xyz="0 -0.1776 0" rpy="1.570796 0 0" />
    <parent link="torso" />
    <child link="shoulder_r" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1" lower="-1.570796" upper="1.570796" />
    <dynamics damping="0.3" friction="0.05" />
  </joint>
  <joint name="tire_lb_joint" type="continuous">
    <origin xyz="-0.192 0.24 0" rpy="1.570796 0 0" />
    <parent link="base_link" />
    <child link="tire_lb" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1" />
    <dynamics damping="0.2" friction="0.1" />
  </joint>
  <joint name="tire_lf_joint" type="continuous">
    <origin xyz="0.192 0.24 0" rpy="1.570796 0 0" />
    <parent link="base_link" />
    <child link="tire_lf" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1" />
    <dynamics damping="0.2" friction="0.1" />
  </joint>
  <joint name="tire_rb_joint" type="continuous">
    <origin xyz="-0.192 -0.24 0" rpy="1.570796 0 0" />
    <parent link="base_link" />
    <child link="tire_rb" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1" />
    <dynamics damping="0.2" friction="0.1" />
  </joint>
  <joint name="tire_rf_joint" type="continuous">
    <origin xyz="0.192 -0.24 0" rpy="1.570796 0 0" />
    <parent link="base_link" />
    <child link="tire_rf" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1" />
    <dynamics damping="0.2" friction="0.1" />
  </joint>
  <joint name="torso_joint" type="fixed">
    <origin xyz="0 0 0.336" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="torso" />
  </joint>
  <joint name="wrist_l_joint" type="revolute">
    <origin xyz="0.336 0 0" rpy="1.570796 0 0" />
    <parent link="forearm_l" />
    <child link="wrist_l" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1" lower="-1.570796" upper="1.570796" />
    <dynamics damping="0.3" friction="0.05" />
  </joint>
  <joint name="wrist_r_joint" type="revolute">
    <origin xyz="0.336 0 0" rpy="1.570796 0 0" />
    <parent link="forearm_r" />
    <child link="wrist_r" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1" lower="-1.570796" upper="1.570796" />
    <dynamics damping="0.3" friction="0.05" />
  </joint>
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.208176 0 0.123929" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar" />
  </joint>
  <!-- ROS2 Control -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="gripper_finger_ll_joint">
      <command_interface name="position" />
      <command_interface name="velocity" />
      <command_interface name="effort" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="gripper_finger_lr_joint">
      <command_interface name="position" />
      <command_interface name="velocity" />
      <command_interface name="effort" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="gripper_finger_rl_joint">
      <command_interface name="position" />
      <command_interface name="velocity" />
      <command_interface name="effort" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="gripper_finger_rr_joint">
      <command_interface name="position" />
      <command_interface name="velocity" />
      <command_interface name="effort" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="tire_lb_joint">
      <command_interface name="velocity" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="tire_lf_joint">
      <command_interface name="velocity" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="tire_rb_joint">
      <command_interface name="velocity" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="tire_rf_joint">
      <command_interface name="velocity" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="shoulder_l_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="shoulder_r_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="elbow_l_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="elbow_r_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="wrist_l_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="wrist_r_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
  </ros2_control>
  <!-- Gazebo -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find robot_description)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>
  <!-- Sensors -->
  <gazebo reference="depth_cam">
    <sensor name="depth_camera" type="depth_camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic>depthcam</topic>
      <pose>0 0 0.01686 0 -1.57 0</pose>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <depth_camera>
        <output>
          <type>depth</type>
        </output>
      </depth_camera>
    </sensor>
  </gazebo>
  <gazebo reference="main_camera">
    <sensor name="main_cam" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic>main_cam</topic>
      <pose>0 0 0 0 -1.57 0</pose>
      <camera>
        <horizontal_fov>2.351</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  <gazebo reference="imu">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic> imu</topic>
      <imu />
    </sensor>
  </gazebo>
  <gazebo reference="lidar">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>lidar</topic>
      <ray>
        <scan>
          <horizontal>
            <samples>640</samples>
            <resolution>1</resolution>
            <min_angle>-1.570796</min_angle>
            <max_angle>1.570796</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>10</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>
</robot>
