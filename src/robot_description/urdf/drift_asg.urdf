    <parent link="wrist_l" />
    <child link="gripper_l" />
  </joint>
  <joint name="gripper_r_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.570796 0 0" />
    <parent link="wrist_r" />
    <child link="gripper_r" />
  </joint>
  <joint name="head_joint" type="fixed">
    <origin xyz="0 0 0.21888" rpy="0 0 0" />
    <parent link="torso" />
    <child link="head" />
  </joint>
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 -0.04633" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="imu" />
  </joint>
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.124906 0 0.074358" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="lidar" />
  </joint>
  <joint name="main_camera_joint" type="fixed">
    <origin xyz="0.0864 0 0.1152" rpy="0 1.570796 0" />
    <parent link="torso" />
    <child link="main_camera" />
  </joint>
  <joint name="shoulder_l_joint" type="revolute">
    <origin xyz="0 0.10368 0" rpy="1.570796 0 0" />
    <parent link="torso" />
    <child link="shoulder_l" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1" lower="-1.570796" upper="1.570796" />
    <dynamics damping="0.3" friction="0.05" />
  </joint>
  <joint name="shoulder_r_joint" type="revolute">
    <origin xyz="0 -0.10656 0" rpy="1.570796 0 0" />
    <parent link="torso" />
    <child link="shoulder_r" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1" lower="-1.570796" upper="1.570796" />
    <dynamics damping="0.3" friction="0.05" />
  </joint>
  <joint name="tire_lb_joint" type="continuous">
    <origin xyz="-0.1152 0.144 0" rpy="1.570796 0 0" />
    <parent link="base_link" />
    <child link="tire_lb" />
    <axis xyz="0 0 -1" />
    <limit effort="10" velocity="10" />
  </joint>
  <joint name="tire_lf_joint" type="continuous">
    <origin xyz="0.1152 0.144 0" rpy="1.570796 0 0" />
    <parent link="base_link" />
    <child link="tire_lf" />
    <axis xyz="0 0 -1" />
    <limit effort="10" velocity="10" />
  </joint>
  <joint name="tire_rb_joint" type="continuous">
    <origin xyz="-0.1152 -0.144 0" rpy="1.570796 0 0" />
    <parent link="base_link" />
    <child link="tire_rb" />
    <axis xyz="0 0 -1" />
    <limit effort="10" velocity="10" />
  </joint>
  <joint name="tire_rf_joint" type="continuous">
    <origin xyz="0.1152 -0.144 0" rpy="1.570796 0 0" />
    <parent link="base_link" />
    <child link="tire_rf" />
    <axis xyz="0 0 -1" />
    <limit effort="10" velocity="10" />
  </joint>
  <joint name="torso_joint" type="fixed">
    <origin xyz="0 0 0.2016" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="torso" />
  </joint>
  <joint name="wrist_l_joint" type="revolute">
    <origin xyz="0.2016 0 0" rpy="1.570796 0 0" />
    <parent link="forearm_l" />
    <child link="wrist_l" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1" lower="-1.570796" upper="1.570796" />
    <dynamics damping="0.3" friction="0.05" />
  </joint>
  <joint name="wrist_r_joint" type="revolute">
    <origin xyz="0.2016 0 0" rpy="1.570796 0 0" />
    <parent link="forearm_r" />
    <child link="wrist_r" />
    <axis xyz="0 0 1" />
    <limit effort="10" velocity="1" lower="-1.570796" upper="1.570796" />
    <dynamics damping="0.3" friction="0.05" />
  </joint>
  <!-- ROS2 Control -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="gripper_finger_ll_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="gripper_finger_lr_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="gripper_finger_rl_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <joint name="gripper_finger_rr_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
      <state_interface name="effort" />
    </joint>
    <!-- <joint name="tire_lb_joint">
      <command_interface name="velocity" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="tire_lf_joint">
      <command_interface name="velocity" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="tire_rb_joint">
      <command_interface name="velocity" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="tire_rf_joint">
      <command_interface name="velocity" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint> -->
    <joint name="shoulder_l_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="shoulder_r_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="elbow_l_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="elbow_r_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="wrist_l_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="wrist_r_joint">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
  </ros2_control>
  <!-- Gazebo -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find robot_description)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>
  <!-- Sensors -->
  <gazebo reference="depth_cam">
    <sensor name="depth_camera" type="depth_camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic>depthcam</topic>
      <pose>0 0 0.010116 0 -1.57 0</pose>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <depth_camera>
        <output>
          <type>depth</type>
        </output>
      </depth_camera>
    </sensor>
  </gazebo>
  <gazebo reference="main_camera">
    <sensor name="main_cam" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic>main_cam</topic>
      <pose>0 0.010116 0 0 -1.57 0</pose>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  <gazebo reference="imu">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic> imu</topic>
      <imu />
    </sensor>
  </gazebo>
  <gazebo reference="lidar">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic>lidar</topic>
      <ray>
        <scan>
          <horizontal>
            <samples>640</samples>
            <resolution>1</resolution>
            <min_angle>-1.570796</min_angle>
            <max_angle>1.570796</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>10</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>
  <gazebo reference="tire_lf">
    <friction>
      <ode>
        <mu>1.0</mu>
        <mu2>1.0</mu2>
      </ode>
    </friction>
  </gazebo>
  <gazebo reference="tire_rf">
    <friction>
      <ode>
        <mu>1.0</mu>
        <mu2>1.0</mu2>
      </ode>
    </friction>
  </gazebo>
  <gazebo reference="tire_lb">
    <friction>
      <ode>
        <mu>1.0</mu>
        <mu2>1.0</mu2>
      </ode>
    </friction>
  </gazebo>
  <gazebo reference="tire_rb">
    <friction>
      <ode>
        <mu>1.0</mu>
        <mu2>1.0</mu2>
      </ode>
    </friction>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>tire_lb_joint</left_joint>
      <right_joint>tire_rb_joint</right_joint>
      <left_joint>tire_lf_joint</left_joint>
      <right_joint>tire_rf_joint</right_joint>
      <wheel_separation>0.288</wheel_separation>
      <wheel_radius>0.0864</wheel_radius>
      <topic>/cmd</topic>
      <odom_topic>/odom</odom_topic>
      <publish_odom_tf>true</publish_odom_tf>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <update_rate>30</update_rate>
      <min_velocity>-2.5</min_velocity>
      <max_velocity>2.5</max_velocity>
      <min_acceleration>-5</min_acceleration>
      <max_acceleration>5</max_acceleration>
      <odom_publish_frequency>30</odom_publish_frequency>
    </plugin>
  </gazebo>
</robot>
